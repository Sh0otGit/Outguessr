{
  "name": "outguessr",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute outguessr-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute outguessr-db --remote --file=migrations/0001_init.sql",
    "db:migrate:local:0002": "wrangler d1 execute outguessr-db --local --file=migrations/0002_results_players.sql",
    "db:migrate:remote:0002": "wrangler d1 execute outguessr-db --remote --file=migrations/0002_results_players.sql",
    "db:migrate:local:0003": "wrangler d1 execute outguessr-db --local --file=migrations/0003_shares.sql",
    "db:migrate:remote:0003": "wrangler d1 execute outguessr-db --remote --file=migrations/0003_shares.sql",
    "db:migrate:local:0004": "wrangler d1 execute outguessr-db --local --file=migrations/0004_submit_rejections.sql",
    "db:migrate:remote:0004": "wrangler d1 execute outguessr-db --remote --file=migrations/0004_submit_rejections.sql"
  },
  "devDependencies": {
    "wrangler": "^4.111.0"
  }
}
